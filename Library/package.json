{
  "name": "@library/source",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "generate-client": "npx nx run prisma-schema:generate-types",
    "back": "npx nx serve back",
    "front": "npx nx serve front",
    "seed:dev": "DOTENV_CONFIG_PATH=.env pnpm nx run prisma-schema:prisma db seed",
    "prisma:format": "npx nx run prisma-schema:prisma format",
    "prisma:reset":"npx nx run prisma-schema:prisma migrate reset",
    "prisma:studio":"npx nx run prisma-schema:prisma studio",
    "create-migration": "npx nx run prisma-schema:migrate dev -- --create-only",
    "postcreate-migration": "npm run generate-client",
    "apply-migration": "npx nx run prisma-schema:migrate deploy",
    "postapply-migration": "npm run generate-client"
  },

  "prisma": {
    "seed": "node libs/prisma-schema/seed.js"
  },
  "private": true,
  "dependencies": {
